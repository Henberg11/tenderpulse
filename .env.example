# Copy this file to .env and fill in real values. Never commit .env.

# --- Database ---
# Two common setups:
#
# 1) Supabase (recommended -- free, reachable from anywhere, not just your
#    home network). Use the "Connection Pooler / Session mode" string from
#    Supabase's dashboard (Settings -> Database), NOT the "direct connection"
#    string -- the direct one is IPv6-only and unreachable from most home
#    networks/Docker setups. If your password contains special characters
#    (@, #, %, :, /, ?), URL-encode them (@ -> %40, # -> %23, etc.) or
#    connections will fail to parse.
#
#    DATABASE_URL=postgresql+asyncpg://postgres.YOUR_PROJECT_REF:YOUR_PASSWORD@YOUR_POOLER_HOST:5432/postgres
#    DATABASE_URL_SYNC=postgresql+psycopg2://postgres.YOUR_PROJECT_REF:YOUR_PASSWORD@YOUR_POOLER_HOST:5432/postgres?sslmode=require
#    DATABASE_SSL_REQUIRE=true
#
# 2) Local Postgres via docker-compose (only reachable on your own machine).
#    "postgres" below is a Docker Compose service name, not a typo.
#
#    DATABASE_URL=postgresql+asyncpg://tenderpulse:tenderpulse@postgres:5432/tenderpulse
#    DATABASE_URL_SYNC=postgresql+psycopg2://tenderpulse:tenderpulse@postgres:5432/tenderpulse
#    DATABASE_SSL_REQUIRE=false
DATABASE_URL=postgresql+asyncpg://tenderpulse:tenderpulse@postgres:5432/tenderpulse
DATABASE_URL_SYNC=postgresql+psycopg2://tenderpulse:tenderpulse@postgres:5432/tenderpulse
DATABASE_SSL_REQUIRE=false

# --- Redis / Celery ---
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/1

# --- AI ---
# Gemini's free tier: no credit card, generous daily limit. Get a key at
# https://aistudio.google.com/apikey
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash
OPENAI_API_KEY=sk-replace-me
AI_MODEL=gpt-4o-mini

# --- App ---
ENVIRONMENT=development
LOG_LEVEL=INFO
STORAGE_DIR=./storage/documents
# Comma-separated list of domains allowed to call this API from a browser.
# "*" (everyone) is fine while this only runs on localhost -- tighten this
# before it's ever reachable from the public internet.
CORS_ALLOWED_ORIGINS=*

# --- Crawling ---
CRAWL_INTERVAL_MINUTES=45
GEM_BASE_URL=https://bidplus.gem.gov.in
CPPP_BASE_URL=https://eprocure.gov.in

# --- Notifications (fill in whichever you use) ---
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
ALERT_EMAIL_TO=
SLACK_WEBHOOK_URL=
